# Copiá este archivo a .env (al lado del docker-compose.yml) y completá los valores.
# El .env NO se sube a git.

# --- Postgres dedicado de Órbita ---
# Generala con: openssl rand -base64 24
POSTGRES_PASSWORD=

# --- Cifrado de certificados en la DB (OBLIGATORIO) ---
# Generala UNA vez con:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ⚠️ Irrecuperable: si la perdés, no se pueden descifrar los certs guardados.
FERNET_KEY=

# --- JWT de sesión (si queda vacío se deriva de FERNET_KEY) ---
# Para uno propio: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# --- Dominio del frontend (Vercel) permitido por CORS. Formato JSON. ---
CORS_ORIGINS=["https://contadores.orbitaglobalmarketing.com"]

# --- ARCA / scraping ---
ARCA_HOMO=false            # false = producción ARCA
SCRAPING_HEADLESS=true     # true en el VPS (sin ventana)
SYNC_HOUR=3                # hora (0-23, AR) del sync automático diario

# --- Zona horaria del contenedor (para SYNC_HOUR) ---
TZ=America/Argentina/Buenos_Aires

# --- Crisp (chat de soporte) — opcional ---
# CRISP_ENABLED=false apaga la sync con el CRM sin borrar las credenciales. Default: true.
CRISP_ENABLED=true
CRISP_WEBSITE_ID=
CRISP_TOKEN_IDENTIFIER=
CRISP_TOKEN_KEY=
CRISP_TIER=website

# --- WhatsApp (alertas, gateway Baileys de Órbita) ---
# Sólo el secreto va acá; URL e inbox tienen default en config.py. Vacío = no se mandan WhatsApp.
# Para que el motor envíe automáticamente, además poné SYNC_ALERTAS_ENABLED=true.
WHATSAPP_BOT_SECRET=
# WHATSAPP_BOT_URL=https://app.orbitaglobalmarketing.com/api/bot/propose
# WHATSAPP_INBOX_ID=492e0ec4-b4be-4e2a-9116-0bbf3355df5d

# --- Email (SMTP) — recuperación de contraseña — opcional ---
# Si SMTP_HOST/SMTP_USER quedan vacíos, el envío es un no-op (el flujo no se rompe; se loguea el link).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# Base pública del frontend para el enlace de recuperación. En prod: el dominio de Vercel.
APP_BASE_URL=https://contadores.orbitaglobalmarketing.com
RESET_TOKEN_HORAS=1
