# Copiá este archivo a .env y completá los valores.

# Clave para cifrar certificados/claves en la base. OBLIGATORIA.
# Generala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Secreto para firmar los JWT de sesión (login de contadores). OPCIONAL:
# si lo dejás vacío se deriva de FERNET_KEY. Para rotarlo aparte, generá uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# false = producción ARCA, true = homologación
ARCA_HOMO=false

# --- Producción (VPS) ---
# Orígenes que pueden llamar a la API (tu frontend). Formato JSON. En dev no hace falta
# (localhost se permite siempre); en prod poné tu dominio.
CORS_ORIGINS=["https://contadores.orbitaglobalmarketing.com"]
# true en el VPS (navegador sin ventana). En Windows local se deja false para ver el bootstrap.
SCRAPING_HEADLESS=true
# Hora (0-23, horario de Argentina) del sync automático diario.
SYNC_HOUR=3
# Por defecto SQLite en data/orbita.db. Dejalo comentado salvo que migres a Postgres.
# DATABASE_URL=sqlite:////srv/orbita/backend/data/orbita.db

# --- Crisp (CRM de contactos) ---
# Cada contador que se registra se crea como contacto en Crisp. OPCIONAL: si los dejás vacíos,
# el registro sigue funcionando igual (sin sincronizar con Crisp).
# Lo más simple: un "Website Token" → Crisp app → Settings → Workspace Settings →
# Advanced Configuration → API Token. Copiá el Identifier y el Key.
CRISP_WEBSITE_ID=
CRISP_TOKEN_IDENTIFIER=
CRISP_TOKEN_KEY=
# Tier del token: "website" (Website Token, lo normal) | "plugin" (token del Marketplace)
CRISP_TIER=website

# --- WhatsApp (Twilio) — envío de alertas ---
# Para PROBAR sin aprobación de Meta: Twilio Console → Messaging → Try it out → Send a WhatsApp
# message → activá el Sandbox y mandá "join <palabra>" desde tu WhatsApp al número que te muestra.
# Copiá Account SID y Auth Token (home de la Console) y el número del sandbox en TWILIO_WHATSAPP_FROM
# (ej. +14155238886). Si quedan vacíos, el envío de WhatsApp es un no-op.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
