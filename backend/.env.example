# Copiá este archivo a .env y completá los valores.

# Clave para cifrar certificados/claves en la base. OBLIGATORIA.
# Generala con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Secreto para firmar los JWT de sesión (login de contadores). OPCIONAL:
# si lo dejás vacío se deriva de FERNET_KEY. Para rotarlo aparte, generá uno con:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# false = producción ARCA, true = homologación
ARCA_HOMO=false

# --- Producción (VPS) ---
# Orígenes que pueden llamar a la API (tu frontend). Formato JSON. En dev no hace falta
# (localhost se permite siempre); en prod poné tu dominio.
CORS_ORIGINS=["https://contadores.orbitaglobalmarketing.com"]
# true en el VPS (navegador sin ventana). En Windows local se deja false para ver el bootstrap.
SCRAPING_HEADLESS=true
# Hora (0-23, horario de Argentina) del sync automático diario.
SYNC_HOUR=3
# Por defecto SQLite en data/orbita.db. Dejalo comentado salvo que migres a Postgres.
# DATABASE_URL=sqlite:////srv/orbita/backend/data/orbita.db

# --- Crisp (CRM de contactos) ---
# Cada contador que se registra se crea como contacto en Crisp. OPCIONAL: si los dejás vacíos,
# el registro sigue funcionando igual (sin sincronizar con Crisp).
# Lo más simple: un "Website Token" → Crisp app → Settings → Workspace Settings →
# Advanced Configuration → API Token. Copiá el Identifier y el Key.
CRISP_WEBSITE_ID=
CRISP_TOKEN_IDENTIFIER=
CRISP_TOKEN_KEY=
# Tier del token: "website" (Website Token, lo normal) | "plugin" (token del Marketplace)
CRISP_TIER=website

# --- WhatsApp — envío de alertas (gateway Baileys de Órbita) ---
# El backend postea las alertas a /api/bot/propose (resuelve contacto + conversación y envía por
# Baileys). La URL y el inbox tienen default en config.py (prod); sólo el SECRETO va acá. Si queda
# vacío, el envío de WhatsApp es un no-op (el motor calcula alertas pero no manda nada).
# WHATSAPP_BOT_URL=https://app.orbitaglobalmarketing.com/api/bot/propose
# WHATSAPP_INBOX_ID=492e0ec4-b4be-4e2a-9116-0bbf3355df5d
WHATSAPP_BOT_SECRET=

# --- Email (SMTP) — envío del enlace de recuperación de contraseña ---
# Cualquier proveedor SMTP sirve (Gmail con App Password, Resend, SendGrid, Mailgun…).
# Si SMTP_HOST o SMTP_USER quedan vacíos, el envío es un no-op: el flujo de recuperación NO se rompe
# (en dev el backend loguea el enlace para poder usarlo igual).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=          # remitente ("De:"); si queda vacío usa SMTP_USER

# Base pública del frontend, para armar el enlace de recuperación ({APP_BASE_URL}/recuperar?token=).
# En dev: http://localhost:5173
APP_BASE_URL=http://localhost:5173
# Validez del enlace de recuperación (horas).
RESET_TOKEN_HORAS=1
# Validez del enlace de confirmación de email (horas).
EMAIL_CONFIRM_TOKEN_HORAS=48
